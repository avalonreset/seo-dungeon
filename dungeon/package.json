{
  "name": "seo-dungeon",
  "version": "1.9.8",
  "description": "A Codex-first 16-bit dungeon crawler interface for SEO audits with legacy Claude compatibility",
  "scripts": {
    "start": "node launch.js",
    "dev": "concurrently \"npm run server\" \"npm run game\"",
    "server": "node server/index.js",
    "game": "vite",
    "build": "vite build",
    "serve": "npx serve dist -l 3000 -s"
  },
  "dependencies": {
    "concurrently": "^9.1.2",
    "express": "^4.21.2",
    "phaser": "^3.87.0",
    "playwright": "^1.58.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "vite": "^6.3.0"
  }
}
