{
  "name": "seo-dungeon",
  "version": "2.2.16",
  "description": "A 16-bit dungeon crawler interface for local AI SEO audits",
  "scripts": {
    "start": "node launch.js",
    "dev": "concurrently \"npm run server\" \"npm run game\"",
    "dev:codex-lane": "set SEO_DUNGEON_APP_PORT=3102&& set SEO_DUNGEON_BRIDGE_PORT=3103&& set SEO_DUNGEON_ALLOWED_ORIGINS=http://localhost:3102,http://127.0.0.1:3102&& npm run dev",
    "start:codex-lane": "set SEO_DUNGEON_APP_PORT=3102&& set SEO_DUNGEON_BRIDGE_PORT=3103&& npm start",
    "server": "node server/index.js",
    "game": "vite",
    "remote": "node scripts/remote-control.mjs",
    "demo:remote-record": "node scripts/record-remote-demo.mjs",
    "demo:remote-intents": "node scripts/record-remote-intents-demo.mjs",
    "demo:desktop-intents": "node scripts/record-desktop-intents-proof.mjs",
    "demo:desktop-proof": "node scripts/record-desktop-proof.mjs",
    "proof:desktop-intents": "node scripts/record-desktop-intents-proof.mjs",
    "proof:desktop": "node scripts/record-desktop-proof.mjs",
    "build": "vite build",
    "test:cli": "node tests/cli-launcher.mjs",
    "test:dialogue": "node tests/dialogue-state.mjs",
    "test:live-bridge": "node tests/live-bridge.mjs",
    "test:remote": "node tests/remote-control.mjs",
    "test:remote-cli": "node tests/remote-control-cli.mjs",
    "test:remote-ui": "node tests/remote-control-ui.mjs",
    "test:remote-bidirectional": "node tests/remote-control-bidirectional.mjs",
    "test:policy": "node tests/prompt-policy.mjs",
    "test:hall": "node tests/hall-scene-regression.mjs",
    "test:smoke": "node tests/run-tests.mjs",
    "test:links": "node tests/link-smoke.mjs",
    "test:all": "npm run test:cli && npm run test:policy && npm run test:dialogue && npm run test:remote && npm run test:remote-cli && npm run test:remote-ui && npm run test:remote-bidirectional && npm run test:live-bridge && npm run test:hall && npm run test:ux && npm run test:smoke && npm run test:links",
    "logs": "node scripts/watch-logs.mjs",
    "serve": "npx serve dist -l 3002 -s",
    "test:ux": "node tests/ux-harness.mjs",
    "test:stress": "node tests/stress-loop.mjs"
  },
  "dependencies": {
    "concurrently": "^10.0.3",
    "express": "^5.2.1",
    "phaser": "^3.87.0",
    "playwright": "^1.61.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "vite": "^8.0.16"
  }
}
