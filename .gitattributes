# Line-ending rules (prevents shell scripts breaking on Windows checkouts)
.gitattributes text eol=lf
* text=auto
*.sh text eol=lf
*.py text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.cff text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ps1 text eol=crlf

# Binary files: never text-normalize, never CRLF-convert, never diff as text.
# This prevents tools like sed/grep (which treat files as text by default)
# from corrupting binary content when they match UTF-8 byte sequences that
# happen to appear inside compressed image data.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.bmp   binary
*.tiff  binary
*.pdf   binary
*.zip   binary
*.tar   binary
*.gz    binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.mp3   binary
*.mp4   binary
*.wav   binary
*.ogg   binary

# Linguist overrides for accurate GitHub language bar
*.md linguist-documentation
*.json linguist-data
docs/** linguist-documentation
schema/** linguist-data
*.sh linguist-detectable=false
*.ps1 linguist-detectable=false
scripts/*.py linguist-generated
